    <!--  FrostyEditableLabel  -->
    <Style TargetType="{x:Type ctrl:FrostyEditableLabel}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ctrl:FrostyEditableLabel}">
                    <StackPanel
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Orientation="Horizontal">
                        <TextBlock
                            x:Name="PART_Label"
                            Margin="2,0,0,0"
                            VerticalAlignment="Stretch"
                            Foreground="{StaticResource FontColor}"
                            Text="{Binding Path=Text, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ctrl:FrostyEditableLabel}}, Mode=TwoWay}" />
                        <TextBox
                            x:Name="PART_TextBox"
                            MinWidth="40"
                            Margin="2,0,10,0"
                            VerticalAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Cursor="IBeam"
                            Visibility="Collapsed" />
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  FrostyImageButton  -->
    <Style TargetType="{x:Type ctrl:FrostyImageButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ctrl:FrostyImageButton}">
                    <Grid Width="88" Height="88">
                        <Button x:Name="PART_Button" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Foreground" Value="{StaticResource FontColor}" />
                                    <Setter Property="Background" Value="{StaticResource ControlBackground}" />
                                    <Setter Property="Padding" Value="2" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border
                                                    x:Name="buttonBorder"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    CornerRadius="4">
                                                    <Grid
                                                        x:Name="g1"
                                                        Width="88"
                                                        Height="88"
                                                        Background="{StaticResource ControlBackground}">
                                                        <Border
                                                            Width="80"
                                                            Height="80"
                                                            Background="{StaticResource ListBackground}" />
                                                        <Border
                                                            Width="88"
                                                            Height="60"
                                                            Background="{StaticResource ListBackground}" />
                                                        <Border
                                                            Width="60"
                                                            Height="88"
                                                            Background="{StaticResource ListBackground}" />
                                                        <StackPanel VerticalAlignment="Center">
                                                            <Label
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Content="{Binding Path=Title, RelativeSource={RelativeSource AncestorType={x:Type ctrl:FrostyImageButton}}}"
                                                                ContentStringFormat="NO {0}"
                                                                FontFamily="Global User Interface"
                                                                FontWeight="Bold"
                                                                Opacity="0.5" />
                                                            <Label
                                                                Margin="0,-10,0,0"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Content="Click to import"
                                                                FontFamily="Global User Interface"
                                                                FontSize="10"
                                                                Opacity="0.5" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="g1" Property="Background" Value="#FF707070" />
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="g1" Property="Background" Value="#FF585858" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Image x:Name="PART_Image" IsHitTestVisible="False" />
                        <Button
                            x:Name="PART_ClearButton"
                            Width="16"
                            Height="16"
                            Margin="0,1,1,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Visibility="Collapsed">
                            <Image Source="/FrostyControls;component/Images/Clear.png" />
                        </Button>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
