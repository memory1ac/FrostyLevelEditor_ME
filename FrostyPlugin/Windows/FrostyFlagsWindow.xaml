<ctrl:FrostyDockableWindow
    x:Class="Frosty.Core.Windows.FrostyFlagsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:Frosty.Controls;assembly=FrostyControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Frosty.Core.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Frosty Flags Calculator"
    Width="400"
    Height="370"
    Background="{StaticResource WindowBackground}"
    Foreground="{StaticResource FontColor}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <ctrl:FrostyDockableWindow.Resources>
        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Opacity" Value="0.5" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.7" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Opacity" Value="1.0" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="{x:Type RadioButton}">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Opacity" Value="0.5" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.7" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Opacity" Value="1.0" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </ctrl:FrostyDockableWindow.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Margin="5"
            Background="#292929">
            <DockPanel>
                <TextBlock Margin="5" Text="Frosty Flags" />
                <TextBlock
                    x:Name="TextBlock_GuidMask"
                    Margin="5"
                    HorizontalAlignment="Right"
                    d:Text="000000"
                    DockPanel.Dock="Right"
                    Text="" />
            </DockPanel>
            <TextBox
                x:Name="TextBox_FrostyFlags"
                Margin="5"
                Padding="5"
                d:Text="183109216"
                Background="#353535"
                BorderBrush="#868686"
                BorderThickness="1"
                Cursor="Arrow"
                IsReadOnly="True" />
        </StackPanel>

        <StackPanel
            x:Name="StackPanel_FrostyFlags"
            Grid.Row="1"
            Margin="5"
            d:Visibility="Visible"
            Background="#292929">
            <CheckBox
                x:Name="CheckBox_SetFrostyFlags_0"
                Click="CheckBox_SetFrostyFlags_Click"
                Content="Unknown Flag" />
            <CheckBox
                x:Name="CheckBox_SetFrostyFlags_1"
                Click="CheckBox_SetFrostyFlags_Click"
                Content="Client Event Connection Target" />
            <CheckBox
                x:Name="CheckBox_SetFrostyFlags_2"
                d:IsChecked="True"
                Click="CheckBox_SetFrostyFlags_Click"
                Content="Server Event Connection Target" />
            <CheckBox
                x:Name="CheckBox_SetFrostyFlags_3"
                Click="CheckBox_SetFrostyFlags_Click"
                Content="Client Property Connection Target" />
            <CheckBox
                x:Name="CheckBox_SetFrostyFlags_4"
                Click="CheckBox_SetFrostyFlags_Click"
                Content="Server Property Connection Target" />
            <CheckBox
                x:Name="CheckBox_SetFrostyFlags_5"
                Click="CheckBox_SetFrostyFlags_Click"
                Content="Client Link Connection Source" />
            <CheckBox
                x:Name="CheckBox_SetFrostyFlags_6"
                d:IsChecked="True"
                Click="CheckBox_SetFrostyFlags_Click"
                Content="Server Link Connection Source" />
            <CheckBox
                x:Name="CheckBox_SetFrostyFlags_7"
                Click="CheckBox_SetFrostyFlags_Click"
                Content="Unused Flag" />
        </StackPanel>

        <UniformGrid
            x:Name="UniformGrid_RealmPropertyFlags"
            Grid.Row="1"
            Margin="5"
            d:Visibility="Hidden"
            Background="#292929"
            Columns="2">
            <StackPanel>
                <TextBlock
                    Margin="5"
                    HorizontalAlignment="Center"
                    Text="Realm" />
                <RadioButton
                    x:Name="RadioButton_SetRealmFlags_0"
                    Click="RadioButton_SetRealmPropertyFlags_Click"
                    Content="Invalid"
                    GroupName="Realm" />
                <RadioButton
                    x:Name="RadioButton_SetRealmFlags_1"
                    Click="RadioButton_SetRealmPropertyFlags_Click"
                    Content="ClientAndServer"
                    GroupName="Realm" />
                <RadioButton
                    x:Name="RadioButton_SetRealmFlags_2"
                    d:IsChecked="True"
                    Click="RadioButton_SetRealmPropertyFlags_Click"
                    Content="Client"
                    GroupName="Realm" />
                <RadioButton
                    x:Name="RadioButton_SetRealmFlags_3"
                    Click="RadioButton_SetRealmPropertyFlags_Click"
                    Content="Server"
                    GroupName="Realm" />
                <RadioButton
                    x:Name="RadioButton_SetRealmFlags_4"
                    Click="RadioButton_SetRealmPropertyFlags_Click"
                    Content="NetworkedClient"
                    GroupName="Realm" />
                <RadioButton
                    x:Name="RadioButton_SetRealmFlags_5"
                    Click="RadioButton_SetRealmPropertyFlags_Click"
                    Content="NetworkedClientAndServer"
                    GroupName="Realm" />
            </StackPanel>
            <StackPanel>
                <TextBlock
                    Margin="5"
                    HorizontalAlignment="Center"
                    Text="PropertyType" />
                <RadioButton
                    x:Name="RadioButton_SetPropertyFlags_0"
                    d:IsChecked="True"
                    Click="RadioButton_SetRealmPropertyFlags_Click"
                    Content="Default"
                    GroupName="PropertyType" />
                <RadioButton
                    x:Name="RadioButton_SetPropertyFlags_1"
                    Click="RadioButton_SetRealmPropertyFlags_Click"
                    Content="Interface"
                    GroupName="PropertyType" />
                <RadioButton
                    x:Name="RadioButton_SetPropertyFlags_2"
                    Click="RadioButton_SetRealmPropertyFlags_Click"
                    Content="Exposed"
                    GroupName="PropertyType" />
                <RadioButton
                    x:Name="RadioButton_SetPropertyFlags_3"
                    Click="RadioButton_SetRealmPropertyFlags_Click"
                    Content="Invalid"
                    GroupName="PropertyType" />

                <TextBlock
                    Margin="5"
                    HorizontalAlignment="Center"
                    Text="Misc" />
                <CheckBox
                    x:Name="CheckBox_SetSourceCantBeStatic"
                    d:IsChecked="True"
                    Click="RadioButton_SetRealmPropertyFlags_Click"
                    Content="SourceCantBeStatic" />
            </StackPanel>
        </UniformGrid>

        <Button
            x:Name="Button_SetFrostyFlags"
            Grid.Row="2"
            Margin="5"
            Padding="5,10"
            Click="Button_SetFrostyFlags_Click"
            Content="Apply Flags" />
    </Grid>

</ctrl:FrostyDockableWindow>
