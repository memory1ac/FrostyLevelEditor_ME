<ctrl:FrostyDockableWindow
    x:Class="Frosty.Core.Windows.ClassSelector"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:Frosty.Controls;assembly=FrostyControls"
    xmlns:ctrl2="clr-namespace:Frosty.Core.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Frosty.Core.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Select a class"
    Width="500"
    Height="400"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid Background="{StaticResource WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="38" />
        </Grid.RowDefinitions>

        <ctrl2:FrostyClassSelector
            x:Name="classSelector"
            ItemDoubleClicked="moduleClassView_MouseDoubleClick"
            SelectedItemChanged="moduleClassView_SelectedItemChanged" />

        <Grid Grid.Row="2" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="75" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="75" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="cancelButton"
                Grid.Column="0"
                Click="cancelButton_Click"
                Content="Cancel" />
            <Button
                x:Name="selectButton"
                Grid.Column="2"
                Click="selectButton_Click"
                Content="Select" />

        </Grid>

    </Grid>
</ctrl:FrostyDockableWindow>
