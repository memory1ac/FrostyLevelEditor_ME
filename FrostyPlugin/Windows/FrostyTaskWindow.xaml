<Window
    x:Class="Frosty.Core.Windows.FrostyTaskWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:Frosty.Core.Controls"
    xmlns:ctrl2="clr-namespace:Frosty.Controls;assembly=FrostyControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Frosty.Core.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title=""
    Width="400"
    Height="150"
    AllowsTransparency="True"
    Background="Transparent"
    ShowInTaskbar="False"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    mc:Ignorable="d">
    <Grid
        x:Name="taskWindow"
        SnapsToDevicePixels="True"
        Visibility="Visible">
        <Border Background="Transparent" />
        <Border
            Width="350"
            Height="125"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{StaticResource ControlBackground}"
            BorderBrush="{StaticResource ListBackground}"
            BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="1" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition Height="23" />
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Vertical">
                    <TextBlock
                        x:Name="taskTextBlock"
                        Margin="0,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Global User Interface"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="{StaticResource FontColor}"
                        Text="Header Text" />
                </StackPanel>

                <Grid Grid.Row="1" Background="{StaticResource WindowBackground}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="26" />
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ProgressBar
                        x:Name="taskProgressBar"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Foreground="{StaticResource ListBackground}"
                        Value="{Binding Path=Progress, RelativeSource={RelativeSource AncestorType={x:Type local:FrostyTaskWindow}, Mode=FindAncestor}}" />
                    <ctrl2:FrostySpinner Width="20" Height="20" />

                    <TextBlock
                        x:Name="statusTextBox"
                        Grid.Column="1"
                        Padding="4,5,4,0"
                        Background="Transparent"
                        FontFamily="Global User Interface"
                        Foreground="{StaticResource FontColor}"
                        Text="{Binding Path=Status, RelativeSource={RelativeSource AncestorType={x:Type local:FrostyTaskWindow}, Mode=FindAncestor}}"
                        TextTrimming="CharacterEllipsis" />

                    <Button
                        x:Name="cancelButton"
                        Grid.Column="2"
                        Margin="0"
                        Cursor="Hand"
                        ToolTip="Cancel the task. (Esc)"
                        Visibility="Collapsed">
                        <Image Source="/FrostyControls;component/Images/CloseWindow.png" />
                        <Button.Style>
                            <Style TargetType="{x:Type Button}">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="{StaticResource FontColor}" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.6" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Opacity" Value="0.4" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.5" />
                                        <Setter Property="ToolTip" Value="Cancelling" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border Background="{TemplateBinding Background}">
                                    <ContentPresenter
                                        Margin="{TemplateBinding Padding}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
