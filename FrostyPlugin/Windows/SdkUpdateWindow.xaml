<ctrl:FrostyDockableWindow
    x:Class="Frosty.Core.Windows.SdkUpdateWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:Frosty.Controls;assembly=FrostyControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Frosty.Core.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    Title="Update Profile SDK"
    Width="450"
    Height="300"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Window.Resources>
        <x:Array x:Key="TestArray" Type="{x:Type local:SdkUpdateTask}">
            <local:SdkUpdateTask DisplayName="Waiting for process to become active" State="CompletedSuccessful" />
            <local:SdkUpdateTask DisplayName="Scanning for type info offset" State="Active" />
            <local:SdkUpdateTask DisplayName="Dumping types from memory" State="Inactive" />
            <local:SdkUpdateTask
                DisplayName="Cross referencing assets"
                State="Inactive"
                StatusMessage="10%" />
            <local:SdkUpdateTask DisplayName="Creating SDK" State="Inactive" />
        </x:Array>
    </Window.Resources>

    <Grid>
        <Grid
            x:Name="pageOne"
            Background="{StaticResource ListBackground}"
            Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>

            <StackPanel
                Margin="4"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <TextBlock Foreground="{StaticResource FontColor}" TextAlignment="Center">
                    <TextBlock.Text>
                        <Binding
                            Path="ProfileName"
                            RelativeSource="{RelativeSource AncestorType={x:Type local:SdkUpdateWindow}}"
                            StringFormat="The SDK for profile '{0}' is out of date" />
                    </TextBlock.Text>
                </TextBlock>
                <TextBlock Text="" />
                <TextBlock
                    Foreground="{StaticResource FontColor}"
                    Text="Please launch the game via Origin, then click Next to begin the process of updating the SDK"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <!--<Button Grid.Column="0" x:Name="quitButton" Content="Quit" Width="50" Height="22" HorizontalAlignment="Left" />-->
                <Button
                    x:Name="nextButton"
                    Grid.Column="1"
                    Width="50"
                    Height="22"
                    HorizontalAlignment="Right"
                    Click="NextButton_Click"
                    Content="Next" />
            </Grid>
        </Grid>
        <Grid
            x:Name="pageTwo"
            Background="{StaticResource ListBackground}"
            Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="30" />
            </Grid.RowDefinitions>

            <StackPanel Margin="10" Orientation="Vertical">
                <TextBlock Foreground="{StaticResource FontColor}" Text="Executing the following tasks:" />
                <ListBox x:Name="tasksListBox" Margin="0,10,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel
                                    Width="16"
                                    Margin="0,0,8,0"
                                    Orientation="Horizontal">
                                    <ctrl:FrostySpinner
                                        x:Name="stateActive"
                                        Width="16"
                                        Visibility="Collapsed" />
                                    <Image
                                        x:Name="stateSuccess"
                                        Width="16"
                                        Source="/FrostyCore;component/Images/Tick.png"
                                        Visibility="Collapsed" />
                                </StackPanel>
                                <TextBlock Foreground="{StaticResource FontColor}" Text="{Binding Path=DisplayName}" />
                                <TextBlock
                                    x:Name="statusText"
                                    Margin="10,0,0,0"
                                    Foreground="{StaticResource FontColor}">
                                    <TextBlock.Text>
                                        <Binding Path="StatusMessage" StringFormat="({0})" />
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Path=StatusMessage}" Value="{x:Null}">
                                    <Setter TargetName="statusText" Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Path=State}" Value="Active">
                                    <Setter TargetName="stateActive" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Path=State}" Value="CompletedSuccessful">
                                    <Setter TargetName="stateSuccess" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Path=State}" Value="CompletedFail">
                                    <Setter TargetName="stateSuccess" Property="Visibility" Value="Visible" />
                                    <Setter TargetName="stateSuccess" Property="Source" Value="/FrostyCore;component/Images/Cross.png" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>


                </ListBox>

            </StackPanel>

            <TextBlock
                x:Name="failMessage"
                Margin="0,0,0,40"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Foreground="{StaticResource FontColor}"
                Text="" />
            <TextBlock
                x:Name="successMessage"
                Margin="0,0,0,40"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Foreground="{StaticResource FontColor}"
                Text="SDK was successfully created. Click finish to restart the Frosty Editor"
                Visibility="Collapsed" />

            <Grid Grid.Row="1" Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <!--<Button Grid.Column="0" x:Name="quitButton" Content="Quit" Width="50" Height="22" HorizontalAlignment="Left" />-->
                <Button
                    x:Name="finishButton"
                    Grid.Column="1"
                    Width="50"
                    Height="22"
                    HorizontalAlignment="Right"
                    Click="FinishButton_Click"
                    Content="Finish"
                    IsEnabled="False" />
            </Grid>
        </Grid>
    </Grid>
</ctrl:FrostyDockableWindow>
