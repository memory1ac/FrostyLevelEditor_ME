<ctrl:FrostyDockableWindow
    x:Class="Frosty.Core.Windows.OptionsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="clr-namespace:Frosty.Core.Controls;assembly=FrostyCore"
    xmlns:ctrl="clr-namespace:Frosty.Controls;assembly=FrostyControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Frosty.Core.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Options"
    Width="600"
    Height="720"
    Loaded="OptionsWindow_Loaded"
    ResizeMode="NoResize"
    SnapsToDevicePixels="True"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid Background="{StaticResource WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition />
            <RowDefinition Height="38" />
        </Grid.RowDefinitions>

        <Grid Background="{StaticResource ListBackground}">
            <TextBlock
                Margin="3"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                DockPanel.Dock="Bottom"
                FontFamily="Global User Interface"
                FontSize="16"
                Foreground="{StaticResource FontColor}"
                Text="Some options will require a restart of Frosty before becoming active" />
        </Grid>

        <ctrl:FrostyTabControl x:Name="optionsTabControl" Grid.Row="1" />

        <Border Grid.Row="2" Background="{StaticResource ListBackground}">
            <Grid Margin="8">
                <DockPanel LastChildFill="False">
                    <Button
                        x:Name="cancelButton"
                        Width="75"
                        Click="cancelButton_Click"
                        Content="Cancel"
                        DockPanel.Dock="Left" />
                    <Button
                        x:Name="saveButton"
                        Width="75"
                        Click="saveButton_Click"
                        Content="Save"
                        DockPanel.Dock="Right" />
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</ctrl:FrostyDockableWindow>
