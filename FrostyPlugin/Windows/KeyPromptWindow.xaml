<ctrl:FrostyDockableWindow
    x:Class="Frosty.Core.Windows.KeyPromptWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:Frosty.Controls;assembly=FrostyControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Frosty.Core.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Enter Key"
    Width="325"
    Height="200"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid Background="{StaticResource ListBackground}">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Margin="4,7,4,4"
            Orientation="Vertical">
            <TextBlock
                Grid.Column="0"
                Margin="2,1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontWeight="Bold"
                Foreground="{StaticResource FontColor}"
                Text="The developers cannot provide the encryption key." />
            <TextBlock
                Grid.Column="0"
                Margin="2,15,2,0"
                VerticalAlignment="Center"
                Foreground="{StaticResource FontColor}"
                Text="This game requires an encryption key before you can" />
            <TextBlock
                Grid.Column="0"
                Margin="2,1"
                VerticalAlignment="Center"
                Foreground="{StaticResource FontColor}"
                Text="access the game files." />
            <TextBlock
                Grid.Column="0"
                Margin="2,18,2,6"
                VerticalAlignment="Center"
                Foreground="{StaticResource FontColor}"
                Text="Please enter the encryption key:" />
            <TextBox
                x:Name="keyTextBox"
                Grid.Column="1"
                Height="22"
                VerticalContentAlignment="Center"
                BorderThickness="1" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="cancelButton"
                Grid.Column="0"
                Width="50"
                Height="22"
                HorizontalAlignment="Left"
                Click="cancelButton_Click"
                Content="Cancel" />
            <Button
                x:Name="doneButton"
                Grid.Column="1"
                Width="50"
                Height="22"
                HorizontalAlignment="Right"
                Click="doneButton_Click"
                Content="Done" />
        </Grid>
    </Grid>
</ctrl:FrostyDockableWindow>
