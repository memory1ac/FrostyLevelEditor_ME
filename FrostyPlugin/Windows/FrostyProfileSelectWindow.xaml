<ctrl:FrostyDockableWindow
    x:Class="Frosty.Core.Windows.FrostyProfileSelectWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="clr-namespace:Frosty.Core.Controls;assembly=FrostyCore"
    xmlns:ctrl="clr-namespace:Frosty.Controls;assembly=FrostyControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Load Profile"
    Width="400"
    Height="250"
    Loaded="ProfileSelectWindow_Loaded"
    ResizeMode="NoResize"
    SnapsToDevicePixels="True"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2" />
            <RowDefinition Height="*" />
            <RowDefinition Height="38" />
        </Grid.RowDefinitions>

        <Grid Background="{StaticResource ListBackground}">
            <StackPanel x:Name="GameInfoStackPanel" Margin="8">
                <TextBlock
                    x:Name="ProfileNameTextBlock"
                    FontSize="14"
                    FontWeight="Medium"
                    Foreground="{StaticResource FontColor}" />
                <TextBlock
                    x:Name="ProfilePathTextBlock"
                    FontSize="10"
                    Foreground="{StaticResource FontColor}" />
            </StackPanel>
            <TextBlock
                x:Name="SelectGameTextBlock"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="14"
                FontWeight="Medium"
                Foreground="{StaticResource FontColor}"
                Text="Select Game" />
        </Grid>

        <Border Grid.Row="1" Background="{StaticResource ControlBackground}" />

        <Grid Grid.Row="2">
            <ListBox
                x:Name="ConfigurationListView"
                Background="{StaticResource WindowBackground}"
                MouseDoubleClick="ConfigurationListView_OnMouseDoubleClick"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                SelectionChanged="ConfigurationListView_OnSelectionChanged">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="true" Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="40" Height="40">
                            <Image x:Name="ColorImage" Source="{Binding Path=Thumbnail}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>

                <ListBox.ItemContainerStyle>
                    <Style BasedOn="{StaticResource {x:Type ListBoxItem}}" TargetType="{x:Type ListBoxItem}">
                        <Setter Property="Padding" Value="4" />
                        <Setter Property="Cursor" Value="Hand" />
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>

        <Grid Grid.Row="3" Background="{StaticResource ListBackground}">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Margin="6,6,0,6"
                    Padding="12,0"
                    Click="RefreshButton_OnClicked"
                    Content="Refresh" />
                <Button
                    x:Name="AddConfigurationButton"
                    Margin="6,6,0,6"
                    Padding="12,0"
                    Click="AddConfigurationButton_OnClick"
                    Content="Add" />
                <Button
                    x:Name="SelectConfigurationButton"
                    Margin="6,6,6,6"
                    Padding="12,0"
                    Click="SelectConfigurationButton_OnClick"
                    Content="Select" />
            </StackPanel>

            <Button
                x:Name="CancelButton"
                Margin="6,6,0,6"
                Padding="12,0"
                HorizontalAlignment="Left"
                Click="CancelButton_OnClick"
                Content="Cancel" />
        </Grid>
    </Grid>
</ctrl:FrostyDockableWindow>
