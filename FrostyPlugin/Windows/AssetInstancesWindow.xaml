<ctrl:FrostyDockableWindow
    x:Class="Frosty.Core.Windows.AssetInstancesWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:Frosty.Core.Converters"
    xmlns:core="clr-namespace:Frosty.Core.Controls"
    xmlns:ctrl="clr-namespace:Frosty.Controls;assembly=FrostyControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Select a class instance"
    Width="600"
    Height="500"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid Background="{StaticResource WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="26" />
            <RowDefinition Height="26" />
            <RowDefinition Height="*" />
            <RowDefinition Height="38" />
        </Grid.RowDefinitions>

        <Grid Background="#2F2F2F">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <DockPanel Margin="0,1,0,1">
                <Border
                    HorizontalAlignment="Left"
                    Background="{StaticResource ControlBackground}"
                    DockPanel.Dock="Left">
                    <StackPanel Margin="6,0,6,0" Orientation="Horizontal">
                        <Button
                            x:Name="createInstanceButton"
                            Height="20"
                            Margin="0,0,0,0"
                            Click="CreateInstanceButton_Click">
                            <StackPanel Margin="4,0,4,0" Orientation="Horizontal">
                                <Image
                                    Grid.Column="0"
                                    Width="16"
                                    Source="/FrostyCore;component/Images/Add.png" />
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Center"
                                    Text="Create Instance" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="deleteInstanceButton"
                            Height="20"
                            Margin="4,0,0,0"
                            Click="DeleteInstanceButton_Click"
                            IsEnabled="False">
                            <StackPanel Margin="4,0,4,0" Orientation="Horizontal">
                                <Image
                                    Grid.Column="0"
                                    Width="16"
                                    Source="/FrostyCore;component/Images/Clear.png" />
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Center"
                                    Text="Delete Instance" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="renameInstanceButton"
                            Height="20"
                            Margin="4,0,0,0"
                            Click="RenameInstanceButton_Click"
                            IsEnabled="False">
                            <StackPanel Margin="4,0,4,0" Orientation="Horizontal">
                                <Image
                                    Grid.Column="0"
                                    Width="16"
                                    Source="/FrostyCore;component/Images/Rename.png" />
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Center"
                                    Text="Rename Instance" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="duplicateInstanceButton"
                            Height="20"
                            Margin="4,0,0,0"
                            Click="DuplicateInstanceButton_Click"
                            IsEnabled="False">
                            <StackPanel Margin="4,0,4,0" Orientation="Horizontal">
                                <!--<Image Grid.Column="0" Source="../Images/Rename.png" Width="16"/>-->
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Center"
                                    Text="Duplicate Instance" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
                <Border
                    Margin="0"
                    HorizontalAlignment="Stretch"
                    Background="Transparent"
                    DockPanel.Dock="Left" />
            </DockPanel>
        </Grid>

        <ctrl:FrostyWatermarkTextBox
            x:Name="filterTextBox"
            Grid.Row="1"
            Margin="1"
            Padding="4,0,0,0"
            VerticalContentAlignment="Center"
            BorderThickness="1"
            KeyUp="filterTextBox_KeyUp"
            LostFocus="filterTextBox_LostFocus"
            WatermarkText="Filter" />
        <ListView
            x:Name="instancesListView"
            Grid.Row="2"
            SelectionChanged="instancesListView_SelectionChanged">
            <ListView.Resources>
                <core:FrostyObjectTypeConverter x:Key="FrostyObjectTypeConverter" />
                <conv:AssetEntryToBitmapSourceConverter x:Key="AssetEntryToBitmapSourceConverter" />
            </ListView.Resources>
            <ListView.ItemContainerStyle>
                <Style BasedOn="{StaticResource baseListViewItemStyle}" TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ListViewItem}">
                                <Border x:Name="Border" Background="Transparent">
                                    <Border.InputBindings>
                                        <MouseBinding Command="{Binding Path=DoubleClickCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Gesture="LeftDoubleClick" />
                                    </Border.InputBindings>
                                    <GridViewRowPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="{StaticResource SubItemHighlight}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="{StaticResource SubItemPressed}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridView.Columns>
                        <GridViewColumn Width="{Binding Path=ActualWidth, ElementName=gridHelper1}">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Id" Tag="Id" />
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Height="22">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Image
                                            x:Name="imageRect"
                                            Grid.Column="0"
                                            Width="16"
                                            Height="16"
                                            Source="{Binding Path=., Converter={StaticResource AssetEntryToBitmapSourceConverter}}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="6,0,0,0"
                                            VerticalAlignment="Center"
                                            FontFamily="MS Reference Sans Serif"
                                            Text="{Binding Path=Id}"
                                            TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="{Binding Path=ActualWidth, ElementName=gridHelper2}">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Type" Tag="Type" />
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Height="22">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontFamily="MS Reference Sans Serif"
                                            Text="{Binding Path=Type}"
                                            TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="{Binding Path=ActualWidth, ElementName=gridHelper3}">
                            <GridViewColumn.Header>
                                <GridViewColumnHeader Content="Guid" Tag="Guid" />
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Height="22">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontFamily="Consolas"
                                            Text="{Binding Path=Guid}"
                                            TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView.Columns>
                </GridView>
            </ListView.View>
        </ListView>
        <Grid
            Grid.Row="2"
            IsHitTestVisible="False"
            Visibility="Hidden">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Grid x:Name="gridHelper1" Grid.Column="0" />
            <Grid x:Name="gridHelper2" Grid.Column="1" />
            <Grid x:Name="gridHelper3" Grid.Column="2" />
        </Grid>

        <Grid Grid.Row="3" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="75" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="75" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="cancelButton"
                Grid.Column="0"
                Click="cancelButton_Click"
                Content="Cancel" />
            <Button
                x:Name="selectButton"
                Grid.Column="2"
                Click="selectButton_Click"
                Content="Select" />

        </Grid>

    </Grid>
</ctrl:FrostyDockableWindow>
