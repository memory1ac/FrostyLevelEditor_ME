    <Style TargetType="{x:Type editors:FrostyVectorControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type editors:FrostyVectorControl}">
                    <Grid Height="19">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition x:Name="gridZ" Width="*" />
                            <ColumnDefinition x:Name="gridW" Width="*" />
                        </Grid.ColumnDefinitions>

                        <DockPanel
                            x:Name="blockX"
                            Grid.Column="0"
                            HorizontalAlignment="Stretch">
                            <Border
                                Background="#802020"
                                BorderBrush="{StaticResource ControlBackground}"
                                BorderThickness="1,1,0,1">
                                <TextBlock
                                    Margin="5,0,5,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource FontColor}"
                                    Text="{Binding Path=XLabel, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Border>
                            <Border BorderBrush="{StaticResource ControlBackground}" BorderThickness="1">
                                <TextBox
                                    x:Name="PART_X"
                                    Margin="3,0,0,0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    Text="{Binding Path=X, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Border>
                        </DockPanel>

                        <DockPanel
                            x:Name="blockY"
                            Grid.Column="1"
                            Margin="1,0,0,0"
                            HorizontalAlignment="Stretch">
                            <Border
                                Background="#208020"
                                BorderBrush="{StaticResource ControlBackground}"
                                BorderThickness="1,1,0,1">
                                <TextBlock
                                    Margin="5,0,5,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource FontColor}"
                                    Text="{Binding Path=YLabel, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Border>
                            <Border BorderBrush="{StaticResource ControlBackground}" BorderThickness="1">
                                <TextBox
                                    x:Name="PART_Y"
                                    Margin="3,0,0,0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    Text="{Binding Path=Y, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Border>
                        </DockPanel>

                        <DockPanel
                            x:Name="blockZ"
                            Grid.Column="2"
                            Margin="1,0,0,0"
                            HorizontalAlignment="Stretch">
                            <Border
                                Background="#005080"
                                BorderBrush="{StaticResource ControlBackground}"
                                BorderThickness="1,1,0,1">
                                <TextBlock
                                    Margin="5,0,5,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource FontColor}"
                                    Text="{Binding Path=ZLabel, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Border>
                            <Border BorderBrush="{StaticResource ControlBackground}" BorderThickness="1">
                                <TextBox
                                    x:Name="PART_Z"
                                    Margin="3,0,0,0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    Text="{Binding Path=Z, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Border>
                        </DockPanel>

                        <DockPanel
                            x:Name="blockW"
                            Grid.Column="3"
                            Margin="1,0,0,0"
                            HorizontalAlignment="Stretch">
                            <Border
                                Background="#808080"
                                BorderBrush="{StaticResource ControlBackground}"
                                BorderThickness="1,1,0,1">
                                <TextBlock
                                    Margin="5,0,5,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource FontColor}"
                                    Text="{Binding Path=WLabel, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Border>
                            <Border BorderBrush="{StaticResource ControlBackground}" BorderThickness="1">
                                <TextBox
                                    x:Name="PART_W"
                                    Margin="3,0,0,0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    Text="{Binding Path=W, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Border>
                        </DockPanel>

                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ControlType" Value="Vec2">
                            <Setter TargetName="blockZ" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="blockW" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="gridZ" Property="Width" Value="0" />
                            <Setter TargetName="gridW" Property="Width" Value="0" />
                        </Trigger>
                        <Trigger Property="ControlType" Value="Vec3">
                            <Setter TargetName="blockW" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="gridW" Property="Width" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style BasedOn="{StaticResource {x:Type editors:FrostyVectorControl}}" TargetType="{x:Type editors:FrostyVec2Control}">
