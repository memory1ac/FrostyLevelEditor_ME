<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Frosty.Core.Controls">


    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/FrostyControls;component/Themes/Generic.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style BasedOn="{StaticResource {x:Type Window}}" TargetType="{x:Type local:FrostyNotification}">
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Border
                        Background="{StaticResource ControlBackground}"
                        BorderBrush="Black"
                        BorderThickness="1">
                        <Grid>
                            <TextBlock
                                Margin="10,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                FontSize="16 "
                                Foreground="{StaticResource FontColor}"
                                Text="{Binding Path=NotificationTitle, RelativeSource={RelativeSource AncestorType={x:Type local:FrostyNotification}}}"
                                TextWrapping="Wrap" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>