<ctrl:FrostyDockableWindow
    x:Class="FrostyEditor.Windows.ModSettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:Frosty.Controls;assembly=FrostyControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FrostyEditor.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Export Mod"
    Width="600"
    Height="530"
    ResizeMode="NoResize"
    SnapsToDevicePixels="True"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Window.Resources>
        <Style
            x:Key="TextBoxValidate"
            BasedOn="{StaticResource {x:Type TextBoxBase}}"
            TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="BorderBrush" Value="Red" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="38" />
        </Grid.RowDefinitions>

        <Grid Background="{StaticResource ListBackground}">
            <DockPanel LastChildFill="True">
                <Grid Margin="5" DockPanel.Dock="Top">
                    <StackPanel>
                        <DockPanel LastChildFill="True">
                            <Label
                                Width="75"
                                Content="Title "
                                FontFamily="Global User Interface" />
                            <TextBox
                                x:Name="modTitleTextBox"
                                Margin="1"
                                VerticalContentAlignment="Center"
                                BorderThickness="1"
                                Style="{StaticResource TextBoxValidate}"
                                Text="Testing" />
                        </DockPanel>
                        <DockPanel LastChildFill="True">
                            <Label
                                Width="75"
                                Content="Author "
                                FontFamily="Global User Interface" />
                            <TextBox
                                x:Name="modAuthorTextBox"
                                Margin="1"
                                VerticalContentAlignment="Center"
                                BorderThickness="1"
                                Style="{StaticResource TextBoxValidate}"
                                Text="Testing" />
                        </DockPanel>
                        <DockPanel LastChildFill="True">
                            <Label
                                Width="75"
                                Content="Version "
                                FontFamily="Global User Interface" />
                            <TextBox
                                x:Name="modVersionTextBox"
                                Grid.Column="1"
                                Margin="1"
                                VerticalContentAlignment="Center"
                                BorderThickness="1"
                                Style="{StaticResource TextBoxValidate}"
                                Text="Testing" />
                        </DockPanel>
                        <DockPanel LastChildFill="True">
                            <Label
                                Width="75"
                                Content="Category "
                                FontFamily="Global User Interface" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.5*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ComboBox
                                    x:Name="modCategoryComboBox"
                                    Grid.Column="0"
                                    Margin="1,1,0,1"
                                    SelectionChanged="modCategoryComboBox_SelectionChanged" />
                                <TextBox
                                    x:Name="modCategoryTextBox"
                                    Grid.Column="1"
                                    Margin="1"
                                    VerticalContentAlignment="Center"
                                    BorderThickness="1"
                                    Style="{StaticResource TextBoxValidate}"
                                    Text="Testing" />
                            </Grid>
                        </DockPanel>
                        <DockPanel LastChildFill="True">
                            <Label
                                Width="75"
                                Content="Link "
                                FontFamily="Global User Interface" />
                            <TextBox
                                x:Name="modPageLinkTextBox"
                                Grid.Column="1"
                                Margin="1"
                                VerticalContentAlignment="Center"
                                BorderThickness="1"
                                Text="" />
                        </DockPanel>
                    </StackPanel>
                </Grid>

                <Grid Margin="5" DockPanel.Dock="Top">
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <ctrl:FrostyImageButton
                            x:Name="iconImageButton"
                            Title="ICON"
                            Margin="0,0,4,0"
                            OnValidate="FrostyImageButton_OnValidate" />
                        <Grid
                            Width="88"
                            Height="88"
                            Margin="0,0,16,0" />
                        <ctrl:FrostyImageButton
                            x:Name="ssImageButton1"
                            Title="IMAGE"
                            Margin="0,0,4,0"
                            OnValidate="FrostyImageButton_OnValidate" />
                        <ctrl:FrostyImageButton
                            x:Name="ssImageButton2"
                            Title="IMAGE"
                            Margin="0,0,4,0"
                            OnValidate="FrostyImageButton_OnValidate" />
                        <ctrl:FrostyImageButton
                            x:Name="ssImageButton3"
                            Title="IMAGE"
                            Margin="0,0,4,0"
                            OnValidate="FrostyImageButton_OnValidate" />
                        <ctrl:FrostyImageButton
                            x:Name="ssImageButton4"
                            Title="IMAGE"
                            Margin="0"
                            OnValidate="FrostyImageButton_OnValidate" />
                    </StackPanel>
                </Grid>

                <TextBox
                    x:Name="modDescriptionTextBox"
                    Margin="5"
                    AcceptsReturn="True"
                    AcceptsTab="True"
                    BorderThickness="1"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto" />
            </DockPanel>
        </Grid>

        <Border Grid.Row="1">
            <Grid Margin="8">
                <DockPanel LastChildFill="False">
                    <Button
                        x:Name="cancelButton"
                        Width="75"
                        Click="cancelButton_Click"
                        Content="Cancel"
                        DockPanel.Dock="Left" />
                    <Button
                        x:Name="saveButton"
                        Width="75"
                        Click="saveButton_Click"
                        Content="Save"
                        DockPanel.Dock="Right" />
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</ctrl:FrostyDockableWindow>
