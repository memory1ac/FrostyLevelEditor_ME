<ctrl2:FrostyWindow
    x:Class="FrostyEditor.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cmd="clr-namespace:FrostyEditor.Commands"
    xmlns:conv="clr-namespace:Frosty.Core.Converters;assembly=FrostyCore"
    xmlns:core="clr-namespace:Frosty.Core.Controls;assembly=FrostyCore"
    xmlns:ctrl2="clr-namespace:Frosty.Controls;assembly=FrostyControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ext="clr-namespace:FrostyEditor.Extensions"
    xmlns:local="clr-namespace:FrostyEditor"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:windows="clr-namespace:FrostyEditor.Windows"
    Title="Frosty Editor"
    Width="1280"
    Height="720"
    MinWidth="500"
    MinHeight="250"
    Closing="FrostyWindow_Closing"
    FrostyLoaded="FrostyWindow_Loaded"
    Icon="/FrostyEditor;component/AppIcon.ico"
    WindowState="Maximized"
    mc:Ignorable="d">

    <ctrl2:FrostyWindow.Resources>
        <conv:BooleanToVisibilityConverter x:Key="booleanToVisibilityConverter" />
        <cmd:ExportModMenuItemCommand x:Key="exportModMenuItemCommand" />
        <ContextMenu x:Key="bookmarksContextMenu">
            <MenuItem Click="contextMenuBookmarkItemOpen_Click" Header="Open asset">
                <MenuItem.Icon>
                    <Image Opacity="0.5" Source="/FrostyEditor;component/Images/OpenAsset.png" />
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Click="contextMenuBookmarkItemFind_Click" Header="Find in explorer" />
        </ContextMenu>
    </ctrl2:FrostyWindow.Resources>

    <Grid x:Name="mainGrid" Background="{StaticResource ListBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="22" />
            <RowDefinition Height="26" />
            <RowDefinition Height="24" />
            <RowDefinition Height="*" />
            <RowDefinition Height="0" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Menu
                x:Name="menu"
                Grid.Column="0"
                Height="22"
                VerticalAlignment="Top">
                <MenuItem Height="22" Header="File">
                    <MenuItem
                        x:Name="NewModMenuItem"
                        Height="22"
                        Click="newModMenuItem_Click"
                        Header="New"
                        InputGestureText="Ctrl+N">
                        <MenuItem.Icon>
                            <Image Source="/FrostyEditor;component/Images/New.png" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        x:Name="OpenModMenuItem"
                        Height="22"
                        Click="openModMenuItem_Click"
                        Header="Open"
                        InputGestureText="Ctrl+O">
                        <MenuItem.Icon>
                            <Image Source="/FrostyEditor;component/Images/Open.png" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        x:Name="SaveModMenuItem"
                        Height="22"
                        Click="saveModMenuItem_Click"
                        Header="Save"
                        InputGestureText="Ctrl+S">
                        <MenuItem.Icon>
                            <Image Source="/FrostyEditor;component/Images/Save.png" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        x:Name="SaveAsModMenuItem"
                        Height="22"
                        Click="saveAsModMenuItem_Click"
                        Header="Save As"
                        InputGestureText="Ctrl+Shift+S">
                        <MenuItem.Icon>
                            <Image Source="/FrostyEditor;component/Images/SaveAs.png" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem
                        x:Name="ExportModMenuItem"
                        Height="22"
                        Command="{StaticResource exportModMenuItemCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}}"
                        Header="Export to Mod">
                        <MenuItem.Icon>
                            <Image Source="/FrostyEditor;component/Images/Compile.png" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem
                        x:Name="ExitMenuItem"
                        Height="22"
                        Click="exitMenuItem_Click"
                        Header="Exit"
                        InputGestureText="Alt+F4">
                        <MenuItem.Icon>
                            <Image Source="/FrostyEditor;component/Images/Exit.png" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <MenuItem
                    x:Name="ToolsMenuItem"
                    Height="22"
                    Header="Tools" />
                <MenuItem Height="22" Header="Window">
                    <MenuItem
                        x:Name="CloseAllDocumentsMenuItem"
                        Click="closeAllDocumentsMenuItem_Click"
                        Header="Close All Documents"
                        InputGestureText="Ctrl + D">
                        <MenuItem.Icon>
                            <Image Source="/FrostyEditor;component/Images/CloseAll.png" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <MenuItem Height="22" Header="Help">
                    <MenuItem
                        x:Name="AboutMenuItem"
                        Click="aboutMenuItem_Click"
                        Header="About Frosty Editor" />
                </MenuItem>
            </Menu>
        </Grid>

        <Grid Grid.Row="1" Background="{StaticResource ListBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border BorderBrush="{StaticResource ControlBackground}" BorderThickness="2,0,2,0">
                <DockPanel Margin="1,1,1,1">
                    <!--  Editor  -->
                    <Border
                        HorizontalAlignment="Left"
                        Background="{StaticResource ControlBackground}"
                        DockPanel.Dock="Left"
                        RenderOptions.EdgeMode="Aliased">
                        <StackPanel Margin="6,0,6,0" Orientation="Horizontal">
                            <Button
                                Width="20"
                                Height="20"
                                Margin="0,0,0,0"
                                Click="newModMenuItem_Click"
                                ToolTip="New Project">
                                <Image Width="16" Source="/FrostyEditor;component/Images/New.png" />
                            </Button>
                            <Button
                                Width="20"
                                Height="20"
                                Margin="4,0,0,0"
                                Click="openModMenuItem_Click"
                                ToolTip="Open Project">
                                <Image Width="16" Source="/FrostyEditor;component/Images/Open.png" />
                            </Button>
                            <Button
                                Width="20"
                                Height="20"
                                Margin="4,0,0,0"
                                Click="saveModMenuItem_Click"
                                ToolTip="Save Project">
                                <Image Width="16" Source="/FrostyEditor;component/Images/Save.png" />
                            </Button>
                            <Button
                                Width="20"
                                Height="20"
                                Margin="4,0,0,0"
                                Click="saveAsModMenuItem_Click"
                                ToolTip="Save Project As">
                                <Image Width="16" Source="/FrostyEditor;component/Images/SaveAs.png" />
                            </Button>
                            <!--<Border Width="1" Background="#D0D0D0" Margin="8,3,2,3"/>-->
                        </StackPanel>
                    </Border>
                    <!--  Editor Toolbar  -->
                    <Border
                        Margin="1,0,0,0"
                        Background="{StaticResource ControlBackground}"
                        DockPanel.Dock="Left"
                        RenderOptions.EdgeMode="Aliased">
                        <ItemsControl x:Name="EditorToolbarItems" Margin="2,1,6,1">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel IsItemsHost="True" Orientation="Horizontal">
                                        <!--  Toolbar bindings go here  -->
                                    </StackPanel>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Height="20"
                                        Margin="4,0,0,0"
                                        Command="{Binding Path=Command}"
                                        ToolTip="{Binding Path=ToolTip}">
                                        <StackPanel
                                            x:Name="panel"
                                            Margin="4,0,4,0"
                                            Orientation="Horizontal">
                                            <Image
                                                x:Name="icon"
                                                Width="16"
                                                Source="{Binding Path=Icon}" />
                                            <TextBlock
                                                x:Name="text"
                                                Margin="4,0,0,0"
                                                Text="{Binding Path=Text}" />
                                        </StackPanel>
                                    </Button>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Path=Icon}" Value="{x:Null}">
                                            <Setter TargetName="icon" Property="Visibility" Value="Collapsed" />
                                            <Setter TargetName="text" Property="Margin" Value="0" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Path=Text}" Value="">
                                            <Setter TargetName="text" Property="Margin" Value="0" />
                                            <Setter TargetName="panel" Property="Margin" Value="0" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border.Style>
                            <Style TargetType="{x:Type Border}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Path=Items.Count, ElementName=EditorToolbarItems}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <!--  Asset Toolbar  -->
                    <Border
                        Margin="1,0,0,0"
                        Background="{StaticResource ControlBackground}"
                        DockPanel.Dock="Left"
                        RenderOptions.EdgeMode="Aliased">
                        <ItemsControl x:Name="AssetEditorToolbarItems" Margin="2,1,6,1">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel IsItemsHost="True" Orientation="Horizontal">
                                        <!--  Toolbar bindings go here  -->
                                    </StackPanel>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Height="20"
                                        Margin="4,0,0,0"
                                        Command="{Binding Path=Command}"
                                        ToolTip="{Binding Path=ToolTip}">
                                        <StackPanel
                                            x:Name="panel"
                                            Margin="4,0,4,0"
                                            Orientation="Horizontal">
                                            <Image
                                                x:Name="icon"
                                                Width="16"
                                                Source="{Binding Path=Icon}" />
                                            <TextBlock
                                                x:Name="text"
                                                Margin="4,0,0,0"
                                                Text="{Binding Path=Text}" />
                                        </StackPanel>
                                    </Button>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Path=Icon}" Value="{x:Null}">
                                            <Setter TargetName="icon" Property="Visibility" Value="Collapsed" />
                                            <Setter TargetName="text" Property="Margin" Value="0" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Path=Text}" Value="">
                                            <Setter TargetName="text" Property="Margin" Value="0" />
                                            <Setter TargetName="panel" Property="Margin" Value="0" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border.Style>
                            <Style TargetType="{x:Type Border}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Path=Items.Count, ElementName=AssetEditorToolbarItems}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <!--  Launch  -->
                    <Border
                        Margin="1,0,0,0"
                        Background="{StaticResource ControlBackground}"
                        DockPanel.Dock="Left"
                        RenderOptions.EdgeMode="Aliased">
                        <StackPanel Margin="6,2,6,2" Orientation="Horizontal">
                            <Button
                                x:Name="LaunchButton"
                                Margin="0"
                                Click="launchButton_Click"
                                IsEnabled="false"
                                ToolTip="Launch game with current project">
                                <StackPanel Margin="4,0,4,0" Orientation="Horizontal">
                                    <Image
                                        Grid.Column="0"
                                        Width="16"
                                        Source="../Images/Play.png" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center"
                                        Text="Launch" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                    <!--  Filler  -->
                    <Border
                        Margin="1,0,0,0"
                        HorizontalAlignment="Stretch"
                        Background="Transparent"
                        DockPanel.Dock="Left"
                        RenderOptions.EdgeMode="Aliased" />
                </DockPanel>
            </Border>
        </Grid>

        <Border
            Grid.Row="2"
            BorderBrush="{StaticResource ControlBackground}"
            BorderThickness="2,2,2,0">
            <ctrl2:FrostyTabControl
                x:Name="TabControl"
                Margin="2,2,2,0"
                SelectionChanged="tabControl_SelectionChanged">
                <ctrl2:FrostyTabControl.Style>
                    <Style TargetType="{x:Type ctrl2:FrostyTabControl}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ctrl2:FrostyTabControl}">
                                    <Grid
                                        x:Name="templateRoot"
                                        ClipToBounds="true"
                                        KeyboardNavigation.TabNavigation="Local"
                                        SnapsToDevicePixels="true">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition x:Name="ColumnDefinition0" />
                                            <ColumnDefinition x:Name="ColumnDefinition1" Width="0" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition x:Name="RowDefinition0" Height="Auto" />
                                            <RowDefinition x:Name="RowDefinition1" Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <ScrollViewer
                                                x:Name="PART_ScrollViewer"
                                                Margin="0,0,0,-1"
                                                Padding="0"
                                                BorderThickness="0"
                                                HorizontalScrollBarVisibility="Hidden"
                                                IsTabStop="False"
                                                VerticalScrollBarVisibility="Disabled">
                                                <TabPanel
                                                    x:Name="headerPanel"
                                                    Grid.Row="0"
                                                    Grid.Column="0"
                                                    Margin="-1,0,0,0"
                                                    Panel.ZIndex="1"
                                                    Background="Transparent"
                                                    IsItemsHost="true"
                                                    KeyboardNavigation.TabIndex="1" />
                                            </ScrollViewer>

                                            <Border Grid.Column="1">
                                                <RepeatButton
                                                    x:Name="PART_ScrollLeft"
                                                    Width="21"
                                                    Content="&lt;">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                            <Border Background="{StaticResource ScrollbarBackground}">
                                                                <Border
                                                                    x:Name="border"
                                                                    Margin="1"
                                                                    Background="{StaticResource ControlBackground}">
                                                                    <Polygon
                                                                        Margin="7,10,0,0"
                                                                        HorizontalAlignment="Left"
                                                                        VerticalAlignment="Top"
                                                                        Fill="{StaticResource ButtonImage}"
                                                                        Points="0,0 3.5,3.5 3.5,-3.5"
                                                                        Stroke="{StaticResource ButtonImage}" />
                                                                </Border>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="{StaticResource ControlHighlight}" />
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="{StaticResource ControlPressed}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Border>

                                            <Border Grid.Column="2">
                                                <RepeatButton
                                                    x:Name="PART_ScrollRight"
                                                    Width="21"
                                                    Content="&gt;">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                            <Border Background="{StaticResource ScrollbarBackground}">
                                                                <Border
                                                                    x:Name="border"
                                                                    Margin="1"
                                                                    Background="{StaticResource ControlBackground}">
                                                                    <Polygon
                                                                        Margin="12,10,0,0"
                                                                        HorizontalAlignment="Left"
                                                                        VerticalAlignment="Top"
                                                                        Fill="{StaticResource ButtonImage}"
                                                                        Points="0,0 -3.5,3.5 -3.5,-3.5"
                                                                        Stroke="{StaticResource ButtonImage}" />
                                                                </Border>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="{StaticResource ControlHighlight}" />
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="{StaticResource ControlPressed}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Border>
                                        </Grid>

                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="TabStripPlacement" Value="Bottom">
                                            <Setter TargetName="headerPanel" Property="Grid.Row" Value="1" />
                                            <!--<Setter Property="Grid.Row" TargetName="contentPanel" Value="0"/>-->
                                            <Setter TargetName="RowDefinition0" Property="Height" Value="*" />
                                            <Setter TargetName="RowDefinition1" Property="Height" Value="Auto" />
                                            <Setter TargetName="headerPanel" Property="Margin" Value="2,0,2,2" />
                                        </Trigger>
                                        <Trigger Property="TabStripPlacement" Value="Left">
                                            <Setter TargetName="headerPanel" Property="Grid.Row" Value="0" />
                                            <Setter TargetName="headerPanel" Property="Grid.Column" Value="0" />
                                            <Setter TargetName="ColumnDefinition0" Property="Width" Value="Auto" />
                                            <Setter TargetName="ColumnDefinition1" Property="Width" Value="*" />
                                            <Setter TargetName="RowDefinition0" Property="Height" Value="*" />
                                            <Setter TargetName="RowDefinition1" Property="Height" Value="0" />
                                            <Setter TargetName="headerPanel" Property="Margin" Value="2,2,0,2" />
                                        </Trigger>
                                        <Trigger Property="TabStripPlacement" Value="Right">
                                            <Setter TargetName="headerPanel" Property="Grid.Row" Value="0" />
                                            <Setter TargetName="headerPanel" Property="Grid.Column" Value="1" />
                                            <Setter TargetName="ColumnDefinition0" Property="Width" Value="*" />
                                            <Setter TargetName="ColumnDefinition1" Property="Width" Value="Auto" />
                                            <Setter TargetName="RowDefinition0" Property="Height" Value="*" />
                                            <Setter TargetName="RowDefinition1" Property="Height" Value="0" />
                                            <Setter TargetName="headerPanel" Property="Margin" Value="0,2,2,2" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="false">
                                            <Setter TargetName="templateRoot" Property="TextElement.Foreground" Value="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ctrl2:FrostyTabControl.Style>
                <ctrl2:FrostyTabControl.Resources>
                    <Style TargetType="ctrl2:FrostyTabItem">
                        <Setter Property="AllowDrop" Value="True" />
                        <EventSetter Event="MouseMove" Handler="TabItem_MouseMove" />
                        <EventSetter Event="DragOver" Handler="TabItem_Move" />
                    </Style>
                </ctrl2:FrostyTabControl.Resources>
                <ctrl2:FrostyTabItem
                    CloseButtonVisible="False"
                    Header="Home Page"
                    Icon="/FrostyEditor;component/Images/Home.png">
                    <Grid Background="{StaticResource ControlBackground}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="64" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  Multiplayer Warning  -->
                        <Grid Margin="2" Background="{StaticResource ListBackground}">
                            <Grid Grid.Row="0" Margin="5">
                                <Image
                                    Width="32"
                                    Margin="20,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Source="/FrostyEditor;component/Images/Warning.png" />
                                <TextBlock
                                    Margin="80,0,50,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource FontColor}"
                                    Text="The developers do not support this tool being used to modify files that impact multiplayer in any way shape or form, and will not provide support to anyone who attempts this."
                                    TextAlignment="Left"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!--  Loaded Plugins / Convenient Links  -->
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1*" />
                                    <RowDefinition Height="2*" />
                                </Grid.RowDefinitions>

                                <Grid
                                    Grid.Row="0"
                                    Margin="2"
                                    Background="{StaticResource ListBackground}">
                                    <ScrollViewer
                                        Grid.Row="0"
                                        Padding="4"
                                        HorizontalScrollBarVisibility="Auto"
                                        VerticalScrollBarVisibility="Auto">
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock
                                                Margin="8"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource FontColor}"
                                                Text="Convenient Links" />
                                            <StackPanel Margin="8,8,0,0" Orientation="Horizontal">
                                                <TextBlock
                                                    Margin="0,0,20,0"
                                                    Foreground="{StaticResource FontColor}"
                                                    Text="Frosty Website:" />
                                                <TextBlock>
                                                    <Hyperlink
                                                        Foreground="{StaticResource FontColor}"
                                                        NavigateUri="http://www.frostytoolsuite.com"
                                                        RequestNavigate="hyperlink_RequestNavigate">
                                                        http://www.frostytoolsuite.com
                                                    </Hyperlink>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Margin="8,8,0,0" Orientation="Horizontal">
                                                <TextBlock
                                                    Margin="0,0,20,0"
                                                    Foreground="{StaticResource FontColor}"
                                                    Text="Frosty Support:" />
                                                <TextBlock>
                                                    <Hyperlink
                                                        Foreground="{StaticResource FontColor}"
                                                        NavigateUri="https://discord.gg/sB8ZUAT"
                                                        RequestNavigate="hyperlink_RequestNavigate">
                                                        https://discord.gg/sB8ZUAT
                                                    </Hyperlink>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Margin="8,8,0,0" Orientation="Horizontal">
                                                <TextBlock
                                                    Margin="0,0,20,0"
                                                    Foreground="{StaticResource FontColor}"
                                                    Text="Frosty Source Code:" />
                                                <TextBlock>
                                                    <Hyperlink
                                                        Foreground="{StaticResource FontColor}"
                                                        NavigateUri="https://github.com/CadeEvs/FrostyToolsuite"
                                                        RequestNavigate="hyperlink_RequestNavigate">
                                                        https://github.com/CadeEvs/FrostyToolsuite
                                                    </Hyperlink>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Margin="8,8,0,0" Orientation="Horizontal">
                                                <TextBlock
                                                    Margin="0,0,20,0"
                                                    Foreground="{StaticResource FontColor}"
                                                    Text="Intel® Texture Works Plugin for Photoshop:" />
                                                <TextBlock>
                                                    <Hyperlink
                                                        Foreground="{StaticResource FontColor}"
                                                        NavigateUri="https://software.intel.com/en-us/articles/intel-texture-works-plugin"
                                                        RequestNavigate="hyperlink_RequestNavigate">
                                                        https://software.intel.com/en-us/articles/intel-texture-works-plugin
                                                    </Hyperlink>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Margin="8,8,0,0" Orientation="Horizontal">
                                                <TextBlock
                                                    Margin="0,0,20,0"
                                                    Foreground="{StaticResource FontColor}"
                                                    Text="GPUOpen-Tools/Compressonator:" />
                                                <TextBlock>
                                                    <Hyperlink
                                                        Foreground="{StaticResource FontColor}"
                                                        NavigateUri="https://github.com/GPUOpen-Tools/Compressonator/releases"
                                                        RequestNavigate="hyperlink_RequestNavigate">
                                                        https://github.com/GPUOpen-Tools/Compressonator/releases
                                                    </Hyperlink>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Margin="8,8,0,0" Orientation="Horizontal">
                                                <TextBlock
                                                    Margin="0,0,20,0"
                                                    Foreground="{StaticResource FontColor}"
                                                    Text="DirectX Texture Library:" />
                                                <TextBlock>
                                                    <Hyperlink
                                                        Foreground="{StaticResource FontColor}"
                                                        NavigateUri="https://github.com/Microsoft/DirectXTex/releases"
                                                        RequestNavigate="hyperlink_RequestNavigate">
                                                        https://github.com/Microsoft/DirectXTex/releases
                                                    </Hyperlink>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Margin="8,8,0,0" Orientation="Horizontal">
                                                <TextBlock
                                                    Margin="0,0,20,0"
                                                    Foreground="{StaticResource FontColor}"
                                                    Text="DirectX End-User Runtime Web Installer:" />
                                                <TextBlock>
                                                    <Hyperlink
                                                        Foreground="{StaticResource FontColor}"
                                                        NavigateUri="https://www.microsoft.com/en-au/download/details.aspx?id=35"
                                                        RequestNavigate="hyperlink_RequestNavigate">
                                                        https://www.microsoft.com/en-au/download/details.aspx?id=35
                                                    </Hyperlink>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>

                                <Grid
                                    Grid.Row="1"
                                    Margin="2"
                                    Background="{StaticResource ListBackground}">
                                    <ListView x:Name="LoadedPluginsList">
                                        <ListView.View>
                                            <ctrl2:FrostyAutoSizedGridView>
                                                <GridView.Columns>
