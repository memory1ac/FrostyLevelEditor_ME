<Window
    x:Class="LevelEditorPlugin.BF1Core.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LevelEditorPlugin.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:LevelEditorPlugin.BF1Core.Views"
    x:Name="Window_Main"
    Title="Battlefield 1 Map Editor"
    Width="{DynamicResource Window_Width}"
    Height="{DynamicResource Window_Height}"
    Closing="Window_Main_Closing"
    ContentRendered="Window_Main_ContentRendered"
    Foreground="{DynamicResource Window_Foreground}"
    Left="200"
    Loaded="Window_Main_Loaded"
    ResizeMode="CanMinimize"
    Top="250"
    Topmost="True"
    WindowStartupLocation="Manual"
    mc:Ignorable="d">

    <Window.Resources>
        <ResourceDictionary Source="/LevelEditorPlugin;component/BF1Core/Themes/Generic.xaml" />
    </Window.Resources>

    <Window.TaskbarItemInfo>
        <TaskbarItemInfo ProgressState="None" />
    </Window.TaskbarItemInfo>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl>
            <TabItem Header="Model Control">
                <views:MeshView x:Name="TabItem_MeshView" />
            </TabItem>
            <TabItem Header="Quick Functions">
                <views:EasyView />
            </TabItem>
            <TabItem Header="Prebuilt Scripts">
                <views:ScriptView />
            </TabItem>
        </TabControl>
    </Grid>

</Window>
