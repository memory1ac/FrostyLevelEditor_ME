<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:LevelEditorPlugin.Converters"
    xmlns:ctrl="clr-namespace:Frosty.Controls;assembly=FrostyControls"
    xmlns:editors="clr-namespace:LevelEditorPlugin.Editors">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/FrostyControls;component/Themes/Generic.xaml" />
        <ResourceDictionary Source="/LevelEditorPlugin;component/Themes/Common.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <conv:SceneLayerIconConverter x:Key="SceneLayerIconConverter" />

    <DataTemplate DataType="{x:Type editors:LayersViewModel}">
        <ctrl:FrostyDockablePanel BorderVisible="False" TitleBarVisible="False">
            <Border BorderBrush="{StaticResource ControlBackground}" BorderThickness="0,2,0,0">
                <TreeView x:Name="PART_LayersTreeView" ItemsSource="{Binding Path=Layers}">
                    <TreeView.ItemContainerStyle>
                        <Style BasedOn="{StaticResource StrechedTreeViewItemStyle}" TargetType="{x:Type TreeViewItem}">
                            <Setter Property="Foreground" Value="{StaticResource FontColor}" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="TreeViewItem.IsExpanded" Value="{Binding Path=IsExpanded, Mode=TwoWay}" />
                            <Setter Property="TreeViewItem.IsSelected" Value="{Binding Path=IsSelected, Mode=TwoWay}" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Path=ChildLayers}">
                            <Grid
                                x:Name="Grid_Bg"
                                HorizontalAlignment="Stretch"
                                Background="Transparent"
                                Opacity="1.0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="26" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Image Width="16" Source="{Binding Path=Entity, Converter={StaticResource SceneLayerIconConverter}}" />
                                    <TextBlock
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Foreground="White"
                                        Text="{Binding Path=LayerName}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <CheckBox VerticalAlignment="Center" IsChecked="{Binding Path=IsVisible}" />
                                </StackPanel>
                            </Grid>

                            <HierarchicalDataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Path=IsVisible}" Value="False">
                                    <Setter TargetName="Grid_Bg" Property="Opacity" Value="0.5" />
                                </DataTrigger>
                            </HierarchicalDataTemplate.Triggers>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>
        </ctrl:FrostyDockablePanel>
    </DataTemplate>

</ResourceDictionary>