<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:Frosty.Controls;assembly=FrostyControls"
    xmlns:editors="clr-namespace:LevelEditorPlugin.Editors"
    xmlns:z="clr-namespace:LevelEditorPlugin.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/FrostyControls;component/Themes/Generic.xaml" />
        <ResourceDictionary Source="/LevelEditorPlugin;component/Themes/Common.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <HierarchicalDataTemplate DataType="{x:Type editors:ToolboxFolderItem}" ItemsSource="{Binding Path=Children}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="19" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Rectangle
                x:Name="imageRect"
                Width="16"
                Height="16"
                Margin="3,0,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Fill="White">
                <Rectangle.OpacityMask>
                    <ImageBrush ImageSource="/FrostyEditor;component/Images/CloseFolder.png" />
                </Rectangle.OpacityMask>
            </Rectangle>

            <TextBlock
                Grid.Column="1"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                Text="{Binding Path=Name}" />
        </Grid>
        <HierarchicalDataTemplate.Triggers>
            <DataTrigger Binding="{Binding Path=IsExpanded}" Value="True">
                <Setter TargetName="imageRect" Property="OpacityMask">
                    <Setter.Value>
                        <ImageBrush ImageSource="/FrostyEditor;component/Images/OpenFolder.png" />
                    </Setter.Value>
                </Setter>
            </DataTrigger>
        </HierarchicalDataTemplate.Triggers>
    </HierarchicalDataTemplate>

    <DataTemplate DataType="{x:Type editors:ToolboxTypeItem}">
        <TextBlock VerticalAlignment="Center" Text="{Binding Path=Name}" />
    </DataTemplate>

    <DataTemplate DataType="{x:Type editors:SchematicsToolboxViewModel}">
        <ctrl:FrostyDockablePanel BorderVisible="False" TitleBarVisible="False">
            <Border BorderBrush="{StaticResource ControlBackground}" BorderThickness="0,2,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Row="0"
                        Margin="1,1,1,1"
                        Background="Transparent">
                        <ctrl:FrostyWatermarkTextBox
                            x:Name="PART_FilterTextBox"
                            Height="24"
                            Padding="4,0,0,0"
                            HorizontalAlignment="Stretch"
                            VerticalContentAlignment="Center"
                            BorderThickness="1"
                            WatermarkText="Filter">
                            <ctrl:FrostyWatermarkTextBox.Text>
                                <Binding Path="FilterText" UpdateSourceTrigger="PropertyChanged" />
                            </ctrl:FrostyWatermarkTextBox.Text>
                        </ctrl:FrostyWatermarkTextBox>
                    </Border>
                    <TreeView
                        Grid.Row="1"
                        editors:DragDropExtension.IsDragDropSource="True"
                        editors:LevelEditorAttachedBehaviors.SelectedItemChangedCommand="{Binding Path=SelectedTypeChangedCommand}"
                        ItemsSource="{Binding Path=Types}">
                        <TreeView.ItemContainerStyle>
                            <Style BasedOn="{StaticResource StrechedTreeViewItemStyle}" TargetType="{x:Type TreeViewItem}">
                                <Setter Property="Foreground" Value="{StaticResource FontColor}" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="TreeViewItem.IsExpanded" Value="{Binding Path=IsExpanded, Mode=TwoWay}" />
                                <Setter Property="TreeViewItem.IsSelected" Value="{Binding Path=IsSelected, Mode=TwoWay}" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Grid>
            </Border>

        </ctrl:FrostyDockablePanel>
    </DataTemplate>

</ResourceDictionary>