<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="clr-namespace:Frosty.Core.Controls;assembly=FrostyCore"
    xmlns:ctrl="clr-namespace:Frosty.Controls;assembly=FrostyControls"
    xmlns:editors="clr-namespace:LevelEditorPlugin.Editors">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/FrostyControls;component/Themes/Generic.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <DataTemplate DataType="{x:Type editors:PropertiesViewModel}">
        <ctrl:FrostyDockablePanel
            BorderVisible="False"
            Foreground="{StaticResource FontColor}"
            TitleBarVisible="False">
            <Border BorderBrush="{StaticResource ControlBackground}" BorderThickness="0,2,0,0">
                <core:FrostyPropertyGrid
                    x:Name="PART_PropertyGrid"
                    editors:PropertyGridExtension.InjectMockData="{Binding Path=MockDataObject}"
                    editors:PropertyGridExtension.InjectPropertyGridData="{Binding Path=ItemsToInject}"
                    editors:PropertyGridExtension.UpdatePropertyGrid="{Binding Path=RefreshPropertyGrid}"
                    Object="{Binding Path=Data}"
                    OnModifiedCommand="{Binding Path=OnPropertyGridModifiedCommand}" />
            </Border>
        </ctrl:FrostyDockablePanel>
    </DataTemplate>

</ResourceDictionary>