<ctrl:FrostyDockableWindow
    x:Class="LevelEditorPlugin.Windows.SchematicsDynamicPortWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="clr-namespace:Frosty.Core.Controls;assembly=FrostyCore"
    xmlns:ctrl="clr-namespace:Frosty.Controls;assembly=FrostyControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LevelEditorPlugin.Windows"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Add Dynamic Port"
    Width="400"
    Height="200"
    ResizeMode="NoResize"
    Topmost="True"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="38" />
        </Grid.RowDefinitions>

        <core:FrostyPropertyGrid
            Grid.Row="0"
            ClassViewVisible="False"
            Object="{Binding Path=Options, RelativeSource={RelativeSource AncestorType={x:Type local:SchematicsDynamicPortWindow}}}" />

        <Grid Grid.Row="1" Background="{StaticResource ListBackground}">
            <Button
                Margin="6"
                Padding="12,0"
                HorizontalAlignment="Right"
                Command="{Binding Path=AddButtonClickedCommand, RelativeSource={RelativeSource AncestorType={x:Type local:SchematicsDynamicPortWindow}}}"
                Content="Add" />
            <Button
                Margin="6"
                Padding="12,0"
                HorizontalAlignment="Left"
                Command="{Binding Path=CancelButtonClickedCommand, RelativeSource={RelativeSource AncestorType={x:Type local:SchematicsDynamicPortWindow}}}"
                Content="Cancel" />
        </Grid>
    </Grid>
</ctrl:FrostyDockableWindow>
